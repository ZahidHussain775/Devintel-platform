# Copy this file to .env.local and fill in your own values.
# .env.local is gitignored and will never be committed.

# GitHub personal access token (used to read public profile/repo data)
# Create one at https://github.com/settings/tokens (no special scopes needed for public data)
GITHUB_TOKEN=

# Google Gemini API key
# Get one for free at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
